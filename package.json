{
  "name": "video-batch-generator",
  "version": "1.0.1",
  "type": "module",
  "description": "Electron batch video generator and account manager UI",
  "main": "electron/main.cjs",
  "author": "Cascade",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port ${VITE_PORT:-5174} --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "sh -lc 'PORT=${VITE_PORT:-5174}; if lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then PORT=$((PORT+1)); fi; VITE_PORT=$PORT concurrently \"npm run dev\" \"wait-on http://localhost:$PORT && electron .\"'",
    "oreateai:smoke": "electron electron/oreateai-smoke.cjs",
    "electron:build": "npm run build && npm --prefix dola-video-standalone ci && electron-builder"
  },
  "build": {
    "appId": "com.cascade.videobatchgenerator",
    "productName": "VideoBatchGenerator",
    "directories": {
      "output": "release3"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "py-dist/wizstar-server",
        "to": "backend/wizstar-server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "oiioii-sdk",
        "to": "oiioii-sdk",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dola-video-standalone",
        "to": "dola-video-standalone",
        "filter": [
          "package.json",
          "package-lock.json",
          "dola-video-gen.mjs",
          "grab-account.mjs",
          "src/**/*",
          "sdk/**/*",
          "node_modules/**/*"
        ]
      },
      {
        "from": "dola-google-login",
        "to": "dola-google-login",
        "filter": [
          "package.json",
          "index.mjs",
          "node_modules/**/*"
        ]
      },
      {
        "from": "oreateai-sdk",
        "to": "oreateai-sdk",
        "filter": [
          "package.json",
          "src/**/*"
        ]
      },
      {
        "from": "lovart-google-login",
        "to": "lovart-google-login",
        "filter": [
          "package.json",
          "package-lock.json",
          "index.mjs",
          "node_modules/**/*"
        ]
      },
      {
        "from": "framia-google-login",
        "to": "framia-google-login",
        "filter": [
          "package.json",
          "package-lock.json",
          "index.mjs",
          "node_modules/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "opencv.js": "^1.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^28.2.4",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  }
}
