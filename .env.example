# MySQL 8.0+ connection used by the local Wizstar FastAPI backend.
WIZSTAR_MYSQL_HOST=127.0.0.1
WIZSTAR_MYSQL_PORT=3306
WIZSTAR_MYSQL_DATABASE=wizstar
WIZSTAR_MYSQL_USER=wizstar
WIZSTAR_MYSQL_PASSWORD=change-me

# Set to 0 when the configured user cannot CREATE DATABASE.
WIZSTAR_MYSQL_AUTOCREATE_DATABASE=1
WIZSTAR_MYSQL_CONNECT_TIMEOUT=10

# Optional Unix socket (when set, host/port are ignored by PyMySQL).
# WIZSTAR_MYSQL_UNIX_SOCKET=/var/run/mysqld/mysqld.sock
